<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ site.nom_agence }}</title>
  <meta name="description" content="{{ description or site.description_seo }}">
  <link rel="icon" type="image/jpeg" href="/images/logo.jpeg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Inter:wght@300;400;500;600&family=Playfair+Display:ital@1&display=swap">
  <link rel="stylesheet" href="/css/style.css">
  {% if canonical %}<link rel="canonical" href="{{ canonical }}">{% endif %}
  <!-- Netlify Identity: handles /admin/ redirect after login -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo"><img src="/images/logo.jpeg" alt="{{ site.nom_agence }}"></a>
    <ul class="nav__links">
      <li><a href="/#about">À Propos</a></li>
      <li><a href="/services/">Services</a></li>
      <li><a href="/creamiir/">Créamiir</a></li>
      <li><a href="/freelances/">Freelances</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
    <div class="nav__cta">
      <a href="/commande/" class="btn btn--gold">Commander</a>
    </div>
    <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <button class="mobile-menu__close">✕</button>
  <nav class="mobile-menu__links">
    <a href="/">Accueil</a>
    <a href="/services/">Services</a>
    <a href="/creamiir/">Créamiir</a>
    <a href="/freelances/">Freelances</a>
    <a href="/contact/">Contact</a>
    <a href="/commande/" class="btn btn--gold" style="margin-top:1rem;display:inline-block;">Commander</a>
  </nav>
</div>

{{ content | safe }}

<footer class="footer">
  <div class="footer__inner container">

    {# ── TOP ROW : Logo + Nav columns ── #}
    <div class="footer__grid">

      {# Brand column #}
      <div class="footer__brand">
        <a href="/" class="footer__logo-link" aria-label="Retour à l'accueil">
          <img src="/images/logo.jpeg" alt="{{ site.nom_agence }}" class="footer__logo">
        </a>
        <p class="footer__tagline">{{ site.adresse }}</p>

        {# ── Social icons (SVG officiels) ── #}
        <div class="footer__social" aria-label="Réseaux sociaux">

          {% if site.facebook %}
          <a href="{{ site.facebook }}" target="_blank" rel="noopener noreferrer" class="footer__social-link footer__social-link--facebook" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
          {% endif %}

          {% if site.instagram %}
          <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer" class="footer__social-link footer__social-link--instagram" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          {% endif %}

          {% if site.linkedin %}
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer" class="footer__social-link footer__social-link--linkedin" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          {% endif %}

          {# WhatsApp always shown if number exists #}
          {% if site.whatsapp %}
          <a href="https://wa.me/{{ site.whatsapp }}?text=Bonjour%20PULSIA%20Agency" target="_blank" rel="noopener noreferrer" class="footer__social-link footer__social-link--whatsapp" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          {% endif %}

        </div>
      </div>

      {# Nav columns #}
      <div class="footer__col">
        <h5>Services</h5>
        <ul>
          <li><a href="/services/">Infographie & Impression</a></li>
          <li><a href="/services/">Digital Growth</a></li>
          <li><a href="/commande/">Commander</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Liens utiles</h5>
        <ul>
          <li><a href="/creamiir/">Créamiir</a></li>
          <li><a href="/freelances/">Freelances</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Nous contacter</h5>
        <ul>
          <li>
            <a href="mailto:{{ site.email }}">
              <span class="footer__contact-icon">✉</span>{{ site.email }}
            </a>
          </li>
          <li>
            <a href="tel:{{ site.telephone | replace(' ', '') }}">
              <span class="footer__contact-icon">☎</span>{{ site.telephone }}
            </a>
          </li>
          {% if site.whatsapp %}
          <li>
            <a href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener">
              <span class="footer__contact-icon">💬</span>WhatsApp
            </a>
          </li>
          {% endif %}
          <li>
            <span class="footer__contact-icon">🕐</span>
            <span style="color:rgba(255,255,255,0.4);font-size:0.85rem;">{{ site.horaires }}</span>
          </li>
        </ul>
      </div>
    </div>

    {# ── BOTTOM BAR ── #}
    <div class="footer__bottom">
      <p class="footer__copyright">
        © <span id="footer-year"></span> {{ site.nom_agence }} · {{ site.adresse }} · Tous droits réservés.
      </p>
      <div class="footer__bottom-links">
        <a href="/contact/">Contact</a>
        <a href="/freelances/">Recrutement</a>
      </div>
    </div>

  </div>
</footer>

<script>
  document.getElementById('footer-year').textContent = new Date().getFullYear();
</script>

<script src="/js/main.js"></script>
<script>
  // Netlify Identity redirect after login
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
